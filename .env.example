# =============================================================================
# Bocanv - Restaurant Ecommerce (Medusa + Next.js)
# =============================================================================
# Copy this file to .env and fill in your values.
# =============================================================================

# --- Backend (Medusa) ---
DATABASE_URL=postgres://user:password@host:5432/dbname
REDIS_URL=redis://default:password@host:6379
BACKEND_URL=https://your-backend.up.railway.app
STORE_CORS=https://your-store.vercel.app
ADMIN_CORS=https://your-backend.up.railway.app
AUTH_CORS=https://your-store.vercel.app
JWT_SECRET=your-jwt-secret
COOKIE_SECRET=your-cookie-secret

# Cloudinary (product + gallery images)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Optional: enable Redis caching (set to true in production)
MEDUSA_FF_CACHING=true

# Stripe (for checkout)
STRIPE_API_KEY=sk_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Admin user (run once after first deploy: npm run create-admin)
MEDUSA_ADMIN_EMAIL=admin@example.com
MEDUSA_ADMIN_PASSWORD=your-secure-password

# --- Storefront (Next.js) ---
MEDUSA_BACKEND_URL=https://your-backend.up.railway.app
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=pk_...
NEXT_PUBLIC_BASE_URL=https://your-store.vercel.app
NEXT_PUBLIC_STRIPE_KEY=pk_...
REVALIDATE_SECRET=your-revalidate-secret
