# Railway → local DB sync (never commit the real file)
# Copy to backend/.env.railway and fill in DATABASE_PUBLIC_URL.
#
# In Railway: PostgreSQL service → enable TCP Proxy → Variables →
# use DATABASE_PUBLIC_URL (not DATABASE_URL) for connections from your laptop.
#
# One line (use single quotes around the URL if it contains special characters):

export DATABASE_PUBLIC_URL='postgresql://USER:PASSWORD@HOST:PORT/railway'
