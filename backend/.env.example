# Database (use port 5433 when using docker-compose)
DATABASE_URL=postgres://postgres:postgres@localhost:5433/medusa

# Redis (use port 6380 when using docker-compose)
REDIS_URL=redis://localhost:6380

# URLs (use env vars in production - no localhost)
BACKEND_URL=http://localhost:9000
STORE_CORS=http://localhost:8000
ADMIN_CORS=http://localhost:9000
AUTH_CORS=http://localhost:8000

# Secrets
JWT_SECRET=supersecret
COOKIE_SECRET=supersecret

# Cloudinary (optional for local dev; required for production image uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Enable Redis caching (set true in production)
MEDUSA_FF_CACHING=false

# Stripe
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=
