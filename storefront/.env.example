# Medusa backend URL (no trailing slash)
MEDUSA_BACKEND_URL=http://localhost:9000

# Publishable API key - run `npm run seed` in backend, then `npx medusa exec ./src/scripts/get-publishable-key.ts` to get it
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=

# Storefront URL for links and metadata
NEXT_PUBLIC_BASE_URL=http://localhost:8000

# Default region (ISO-2 lowercase). Bocanv is Denmark-only.
NEXT_PUBLIC_DEFAULT_REGION=dk

# Catering: product handle(s), comma-separated (default empanada-catering). Matches Medusa product handle, not the URL path /catering.
NEXT_PUBLIC_CATERING_PRODUCT_HANDLES=empanada-catering
# Optional: if set and the collection exists in Admin, that collection is used instead of product handles above.
# NEXT_PUBLIC_CATERING_COLLECTION_HANDLE=
# Optional: product option title for frozen/baked variants (default Preparation)
# NEXT_PUBLIC_CATERING_PREPARATION_OPTION_TITLE=Preparation
# Optional: single metadata key on the product for catering card blurb (overrides default key order: catering_description, short_description, description, subtitle)
# NEXT_PUBLIC_CATERING_DESCRIPTION_METADATA_KEY=catering_description

# Stripe publishable key for checkout
NEXT_PUBLIC_STRIPE_KEY=

# Medusa payments (optional)
NEXT_PUBLIC_MEDUSA_PAYMENTS_PUBLISHABLE_KEY=
NEXT_PUBLIC_MEDUSA_PAYMENTS_ACCOUNT_ID=

# Next.js on-demand revalidation secret
REVALIDATE_SECRET=supersecret

# Cloudinary (optional, for gallery image optimization)
# MEDUSA_CLOUD_S3_HOSTNAME=
# MEDUSA_CLOUD_S3_PATHNAME=
